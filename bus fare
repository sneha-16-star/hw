class Vehicle:
    def __init__(self, name, mileage, capacity):
        self.name = name
        self.mileage = mileage
        self.capacity = capacity

    def fare(self):
        # Default fare: capacity multiplied by 100
        return self.capacity * 100

class Bus(Vehicle):
    def fare(self):
        # Inherit the base fare from the parent class
        base_amount = super().fare()
        
        # Calculate final fare with a 10% maintenance charge
        total_fare = base_amount + (0.1 * base_amount)
        return total_fare

# Example usage:
school_bus = Bus("School Volvo", 12, 50)
print(f"Total Bus fare is: {school_bus.fare()}")
