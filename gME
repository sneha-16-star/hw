import pygame
import random

pygame.init()

screen = pygame.display.set_mode((600, 400))
clock = pygame.time.Clock()

# Colors
WHITE = (255, 255, 255)
RED = (255, 0, 0)
BLUE = (0, 0, 255)

# Player
player = pygame.Rect(300, 200, 30, 30)

# Enemies
enemies = []
for i in range(7):
    x = random.randint(0, 570)
    y = random.randint(0, 370)
    enemies.append(pygame.Rect(x, y, 30, 30))

score = 0
speed = 5

running = True
while running:
    screen.fill(WHITE)

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False

    # Movement
    keys = pygame.key.get_pressed()
    if keys[pygame.K_LEFT]:
        player.x -= speed
    if keys[pygame.K_RIGHT]:
        player.x += speed
    if keys[pygame.K_UP]:
        player.y -= speed
    if keys[pygame.K_DOWN]:
        player.y += speed

    # Draw player
    pygame.draw.rect(screen, BLUE, player)

    # Draw enemies + collision check
    for enemy in enemies:
        pygame.draw.rect(screen, RED, enemy)

        if player.colliderect(enemy):
            score += 1
            enemy.x = random.randint(0, 570)
            enemy.y = random.randint(0, 370)

    # Score display (simple window title)
    pygame.display.set_caption("Score: " + str(score))

    pygame.display.update()
    clock.tick(60)

pygame.quit()
