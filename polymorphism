# Class BMW
class BMW:
    def speed(self):
        print("BMW speed is 250 km/h")

# Class Ferrari
class Ferrari:
    def speed(self):
        print("Ferrari speed is 350 km/h")

# Function demonstrating polymorphism
def show_speed(car):
    car.speed()

# Creating objects
car1 = BMW()
car2 = Ferrari()

# Using polymorphism
show_speed(car1)
show_speed(car2)
